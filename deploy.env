# docs/scripts/deploy_nexus_server.sh 的非敏感配置模板。
# 复制为 deploy.env 后填写真实参数。
# 当前部署模式为接入已存在的 Nexus 网络，不创建创世链。

# 可选：默认使用 https://github.com/nexus-blockchain/nexus.git
# GITHUB_REPO_URL="https://github.com/nexus-blockchain/nexus.git"
DEPLOY_REF="main"
# 条件必填：INSTALL_NGINX=true 时需要
RPC_DOMAIN="earniverse.duckdns.org"
# 条件必填：ENABLE_UFW=true 时需要
ADMIN_IP="38.76.174.79"
# 条件必填：INSTALL_CERTBOT=true 时需要
CERTBOT_EMAIL="mabelithaiceta@gmail.com"

# 现网 bootnodes。请替换为一个或多个可访问的现有节点。
# 多个 bootnodes 时，放在同一对引号内，用空格分隔。
BOOTNODES="/ip4/80.96.113.85/tcp/30333/p2p/12D3KooWPRvdc8wcwMfFt2RDh3tvZKDqKezPj9vn1oo9m8FuKjdf"

# 可选配置
CHAIN="/root/scripts/mainnet-raw.json"
INSTALL_DIR="/opt/nexus"
BIN_INSTALL_PATH="/usr/local/bin/nexus-node"
DATA_ROOT="/data/nexus"
LOG_ROOT="/var/log/nexus"
DEPLOY_LOG_DIR="/var/log/nexus/deploy"

VALIDATOR_NAME="Validator-duck"
RPC_NAME="RPC-Public"

VALIDATOR_P2P_PORT="30333"
VALIDATOR_RPC_PORT="9944"
VALIDATOR_PROM_PORT="9615"
RPC_P2P_PORT="30334"
RPC_RPC_PORT="9947"
RPC_PROM_PORT="9616"

SSH_PORT="22"
NODE_USER="root"
ENABLE_UFW="false"
OPEN_RPC_P2P="true"
INSTALL_NGINX="true"
INSTALL_CERTBOT="true"
GIT_CLONE_DEPTH="1"
GENERATE_KEYS="true"

# 仅在 GENERATE_KEYS=false 时填写，用于复用已有验证者助记词。
VALIDATOR_MNEMONIC="mirror note close tiger inner decrease rowd cattle neither unable log service"
VALIDATOR_ADDRESS="X4YQ4TeZ3L11t9wkAg1dZLjpoZNJzNJBSUTWAiRxTzZfWC34A"

# 是否在部署完成后自动执行链上注册（bond + setKeys + validate）
REGISTER_VALIDATOR="true"
# 验证者佣金百分比（0-100）
VALIDATOR_COMMISSION="10"

# 敏感选项默认关闭。
# 如果设为 true，会把助记词额外写入仅 root 可读文件；脚本不会再把助记词打印到日志或 summary。
WRITE_MNEMONIC_FILE="true"
MNEMONIC_FILE="/root/nexus-validator-mnemonic.txt"
