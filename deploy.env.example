# docs/scripts/deploy_nexus_server.sh 的非敏感配置模板。
# 复制为 deploy.env 后填写真实参数。
# 当前部署模式为接入已存在的 Nexus 网络，不创建创世链。

# 远程服务器配置。用于在本机执行 remote_deploy.sh 时同步代码并触发远程部署。
SERVER_HOST="服务器IP"
SERVER_USER="root"
SERVER_PORT="22"
SERVER_DIR="/root/nodedeploy"

# 可选：默认使用 https://github.com/nexus-blockchain/nexus.git
# GITHUB_REPO_URL="https://github.com/nexus-blockchain/nexus.git"
DEPLOY_REF="main"

# 部署模式：
#   validator -> 仅部署验证者节点
#   rpc       -> 仅部署 RPC 节点
#   both      -> 同时部署验证者 + RPC
DEPLOY_MODE="validator"

# Chain spec 路径。支持以下写法：
#   1. 不设置（注释掉）→ 默认使用脚本同目录下的 mainnet-raw.json
#   2. 文件名（如 "mainnet"）→ 自动在脚本目录下查找 mainnet-raw.json
#   3. 绝对路径（如 "/root/scripts/mainnet-raw.json"）
# CHAIN="/path/to/your/chain-spec-raw.json"

# 条件必填：DEPLOY_MODE=rpc 或 both 且 INSTALL_NGINX=true 时需要
RPC_DOMAIN="rpc.your-domain.com"
# 条件必填：ENABLE_UFW=true 时需要
ADMIN_IP="<YOUR_PUBLIC_IP>"
# 条件必填：DEPLOY_MODE=rpc 或 both 且 INSTALL_CERTBOT=true 时需要
CERTBOT_EMAIL="ops@example.com"

# 现网 bootnodes。请替换为一个或多个可访问的现有节点。
# 多个 bootnodes 时，放在同一对引号内，用空格分隔。
# 格式：/ip4/<IP>/tcp/<PORT>/p2p/<PEER_ID>
# 注意：不要保留尖括号 < >，直接填写真实值。
BOOTNODES="/ip4/1.2.3.4/tcp/30333/p2p/12D3KooWxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 可选配置
# 默认自动选择可用空间最大的磁盘，并把源码、节点数据、日志、IPFS 放到 <挂载点>/nexus。
AUTO_STORAGE="true"
STORAGE_MIN_FREE_GB="20"
# 如需手动指定存储根目录，取消下一行注释。
# STORAGE_ROOT="/www/nexus"
BIN_INSTALL_PATH="/usr/local/bin/nexus-node"

# 仅 DEPLOY_MODE=validator 或 both 时使用
VALIDATOR_NAME="Validator-1"
# 仅 DEPLOY_MODE=rpc 或 both 时使用
RPC_NAME="RPC-Public"

# 仅 DEPLOY_MODE=validator 或 both 时使用
VALIDATOR_P2P_PORT="30333"
VALIDATOR_RPC_PORT="9944"
VALIDATOR_PROM_PORT="9615"
# 仅 DEPLOY_MODE=rpc 或 both 时使用
RPC_P2P_PORT="30334"
RPC_RPC_PORT="9947"
RPC_PROM_PORT="9616"

SSH_PORT="22"
NODE_USER="root"
ENABLE_UFW="false"
# 仅 DEPLOY_MODE=rpc 或 both 时使用
OPEN_RPC_P2P="true"
# 仅 DEPLOY_MODE=rpc 或 both 时使用
INSTALL_NGINX="true"
# 仅 DEPLOY_MODE=rpc 或 both 时使用
INSTALL_CERTBOT="true"
GIT_CLONE_DEPTH="1"

# 必填：仅 DEPLOY_MODE=validator 或 both 时需要。
# 验证者助记词和对应的 X 地址（SS58 prefix 273）
VALIDATOR_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
VALIDATOR_ADDRESS="X..."

# 仅 DEPLOY_MODE=validator 或 both 时生效：是否在部署完成后自动执行链上注册（bond + setKeys + validate）
REGISTER_VALIDATOR="true"
# 仅 DEPLOY_MODE=validator 或 both 时生效：验证者佣金百分比（0-100）
VALIDATOR_COMMISSION="100"

# IPFS Kubo 安装与 systemd 自启动。默认启用，设为 false 可跳过。
# IPFS_PATH 默认由自动存储规划设置为 <STORAGE_ROOT>/ipfs。
INSTALL_IPFS="true"
IPFS_VERSION="0.40.1"
# IPFS_PATH="/www/nexus/ipfs"
IPFS_USER="root"

# 敏感选项默认关闭。
# 如果设为 true，会把助记词额外写入仅 root 可读文件。
# 仅 DEPLOY_MODE=validator 或 both 时生效。
WRITE_MNEMONIC_FILE="false"
MNEMONIC_FILE="/root/nexus-validator-mnemonic.txt"
